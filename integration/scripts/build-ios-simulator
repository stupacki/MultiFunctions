#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
IOS_APP_DIR="$ROOT_DIR/integration/ios-device-app"

xcodebuild \
  -project "$IOS_APP_DIR/MultiFunctionsIntegration.xcodeproj" \
  -scheme MultiFunctionsIntegration \
  -configuration Debug \
  -sdk iphonesimulator \
  -derivedDataPath "$IOS_APP_DIR/build/DerivedData" \
  CODE_SIGNING_ALLOWED=NO \
  ONLY_ACTIVE_ARCH=YES \
  ARCHS=arm64 \
  build "$@"
