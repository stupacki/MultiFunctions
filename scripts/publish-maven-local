#!/usr/bin/env sh
set -eu

usage() {
  cat <<'EOF'
Usage: ./scripts/publish-maven-local [VERSION]

Publishes all multi-functions artifacts to Maven Local.
When VERSION is provided, it overrides artifactVersion from gradle.properties.

Examples:
  ./scripts/publish-maven-local
  ./scripts/publish-maven-local 2.1.0
EOF
}

if [ "$#" -gt 1 ]; then
  usage
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ "$#" -eq 1 ]; then
  ./gradlew publishToMavenLocal -PartifactVersion="$1"
else
  ./gradlew publishToMavenLocal
fi
